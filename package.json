{
  "name": "the-brain",
  "version": "0.1.0",
  "description": "Local persistent memory plugin for Claude Code — graph-backed project knowledge, decisions, review findings and experiences.",
  "type": "module",
  "bin": {
    "brain": "./dist/bin/brain.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "postinstall": "node node_modules/kuzu/install.js",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx",
    "mcp": "tsx src/mcp/server.ts",
    "serve": "tsx src/graphql/server.ts",
    "test": "node test/run.mjs",
    "test:raw": "node --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "brain": "tsx src/bin/brain.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "graphql": "^16.9.0",
    "graphql-scalars": "^1.23.0",
    "graphql-yoga": "^5.0.0",
    "kuzu": "^0.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "kuzu@0.11.3": true,
    "onnxruntime-node@1.24.3": true,
    "protobufjs@7.6.4": true,
    "sharp@0.34.5": true
  },
  "overrides": {
    "cmake-js": {
      "tar": "^7.5.16"
    }
  }
}
