{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/hooks/inject.js\"",
            "timeout": 30,
            "statusMessage": "🧠 Loading project memory..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/hooks/learn.js\"",
            "timeout": 30,
            "statusMessage": "🧠 Learning from response..."
          }
        ]
      }
    ]
  }
}
