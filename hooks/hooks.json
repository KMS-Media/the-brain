{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/inject.sh\"",
            "timeout": 30,
            "statusMessage": "🧠 Loading project memory..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/learn.sh\"",
            "timeout": 30,
            "statusMessage": "🧠 Learning from response..."
          }
        ]
      }
    ]
  }
}
